---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage
  frontmatter={{
    title: '宇辰AI编程 · 教程',
    description: 'AI 前沿技术与实用技巧分享',
    template: 'splash',
    pagefind: false,
  }}
>
  <!-- Hero Section -->
  <section class="text-center py-16 px-4">
    <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="color: var(--sl-color-text);">
      宇辰AI编程
    </h1>
    <p class="text-xl sm:text-2xl leading-relaxed max-w-2xl mx-auto mb-8" style="color: var(--sl-color-gray-3);">
      AI 前沿技术与实用技巧分享<br />
      从零开始，系统掌握 AI 编程工具<br />
      让每个人都能用好 AI
    </p>
    <a
      href="#tutorials"
      class="inline-block px-8 py-3 rounded-full text-lg font-semibold text-white no-underline transition-transform hover:scale-105"
      style="background-color: var(--sl-color-accent);"
    >
      浏览教程 ↓
    </a>
  </section>

  <!-- Tutorial Section: 使用端工具教程 -->
  <section id="tutorials" class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold mb-6" style="color: var(--sl-color-text);">
      使用端工具教程
    </h2>
    <div class="grid sm:grid-cols-2 gap-6">
      <!-- OpenClaw Card (clickable) -->
      <a
        href="/openclaw/"
        class="tutorial-card tutorial-card--clickable relative block rounded-xl p-6 no-underline transition-all duration-300"
        style="background-color: var(--sl-color-bg-nav); border: 1px solid var(--sl-color-gray-5);"
      >
        <div class="text-4xl mb-4">🐾</div>
        <h3 class="text-xl font-bold mb-1" style="color: var(--sl-color-text);">OpenClaw</h3>
        <p class="text-sm mb-3" style="color: var(--sl-color-gray-3);">从零搭建你的 AI 助手</p>
        <div class="flex items-center justify-between">
          <span class="text-sm" style="color: var(--sl-color-gray-3);">11 章节</span>
          <span class="text-sm font-semibold" style="color: var(--sl-color-accent);">开始学习 →</span>
        </div>
      </a>

      <!-- Claude Code Card (not clickable, coming soon) -->
      <div
        class="tutorial-card relative rounded-xl p-6 opacity-75"
        style="background-color: var(--sl-color-bg-nav); border: 1px solid var(--sl-color-gray-5);"
      >
        <span
          class="absolute top-3 right-3 text-xs px-3 py-1 rounded-full"
          style="background-color: var(--sl-color-gray-5); color: var(--sl-color-gray-3);"
        >
          即将上线
        </span>
        <div class="text-4xl mb-4">🤖</div>
        <h3 class="text-xl font-bold mb-1" style="color: var(--sl-color-text);">Claude Code</h3>
        <p class="text-sm" style="color: var(--sl-color-gray-3);">AI 编程助手实战指南</p>
      </div>
    </div>
  </section>

  <!-- Tutorial Section: 工具类教程 -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold mb-6" style="color: var(--sl-color-text);">
      工具类教程
    </h2>
    <div class="grid sm:grid-cols-2 gap-6">
      <!-- MCP 配置 Card (not clickable, coming soon) -->
      <div
        class="tutorial-card relative rounded-xl p-6 opacity-75"
        style="background-color: var(--sl-color-bg-nav); border: 1px solid var(--sl-color-gray-5);"
      >
        <span
          class="absolute top-3 right-3 text-xs px-3 py-1 rounded-full"
          style="background-color: var(--sl-color-gray-5); color: var(--sl-color-gray-3);"
        >
          即将上线
        </span>
        <div class="text-4xl mb-4">⚡</div>
        <h3 class="text-xl font-bold mb-1" style="color: var(--sl-color-text);">MCP 配置</h3>
        <p class="text-sm" style="color: var(--sl-color-gray-3);">模型上下文协议实战</p>
      </div>

      <!-- Skill 编写 Card (not clickable, coming soon) -->
      <div
        class="tutorial-card relative rounded-xl p-6 opacity-75"
        style="background-color: var(--sl-color-bg-nav); border: 1px solid var(--sl-color-gray-5);"
      >
        <span
          class="absolute top-3 right-3 text-xs px-3 py-1 rounded-full"
          style="background-color: var(--sl-color-gray-5); color: var(--sl-color-gray-3);"
        >
          即将上线
        </span>
        <div class="text-4xl mb-4">🧩</div>
        <h3 class="text-xl font-bold mb-1" style="color: var(--sl-color-text);">Skill 编写</h3>
        <p class="text-sm" style="color: var(--sl-color-gray-3);">自定义技能开发指南</p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="max-w-4xl mx-auto px-4 py-12 mt-8 text-center" style="border-top: 1px solid var(--sl-color-gray-5);">
    <p class="text-lg font-bold mb-4" style="color: var(--sl-color-text);">宇辰AI编程</p>
    <div class="flex justify-center gap-6 mb-4 text-sm" style="color: var(--sl-color-gray-3);">
      <span>个人微信: 待补充</span>
      <span>交流群: 右上角扫码</span>
    </div>
    <p class="text-sm" style="color: var(--sl-color-gray-3);">
      &copy; 2026 宇辰AI编程 &middot; learn.aiqqyc.com
    </p>
  </footer>
</StarlightPage>

<style>
  .tutorial-card--clickable:hover {
    transform: translateY(-0.25rem);
    border-color: var(--sl-color-accent) !important;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
  }

  .tutorial-card {
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
  }
</style>

<style is:global>
  /* Hide Starlight's auto-generated page title on homepage */
  .content-panel:has(h1#_top) {
    display: none;
  }
</style>
