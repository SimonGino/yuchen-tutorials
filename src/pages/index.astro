---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage
  frontmatter={{
    title: '宇辰AI编程 · 教程',
    description: 'AI 前沿技术与实用技巧分享',
    template: 'splash',
    pagefind: false,
  }}
>
  <div class="not-content homepage">
    <!-- Profile Banner -->
    <div class="profile-banner">
      <img src="/images/avatar-cropped.png" alt="宇辰" class="profile-avatar" width="64" height="64" />
      <div>
        <p class="profile-name">宇辰AI编程</p>
        <p class="profile-tagline">AI 前沿技术与实用技巧分享，让每个人都能用好 AI</p>
      </div>
    </div>

    <!-- Tutorial Cards -->
    <section class="tutorial-section">
      <h2 class="section-title">使用端工具教程</h2>
      <div class="card-grid">
        <a href="/openclaw/" class="tutorial-card tutorial-card--clickable">
          <div class="card-icon">🦞</div>
          <h3 class="card-title">OpenClaw</h3>
          <p class="card-desc">从零搭建你的 AI 助手</p>
          <div class="card-meta">
            <span>11 章节</span>
            <span class="card-cta">开始学习 →</span>
          </div>
        </a>
        <div class="tutorial-card tutorial-card--disabled">
          <span class="card-badge">即将上线</span>
          <div class="card-icon">🤖</div>
          <h3 class="card-title">Claude Code</h3>
          <p class="card-desc">AI 编程助手实战指南</p>
        </div>
      </div>
    </section>

    <section class="tutorial-section">
      <h2 class="section-title">工具类教程</h2>
      <div class="card-grid">
        <div class="tutorial-card tutorial-card--disabled">
          <span class="card-badge">即将上线</span>
          <div class="card-icon">⚡</div>
          <h3 class="card-title">MCP 配置</h3>
          <p class="card-desc">模型上下文协议实战</p>
        </div>
        <div class="tutorial-card tutorial-card--disabled">
          <span class="card-badge">即将上线</span>
          <div class="card-icon">🧩</div>
          <h3 class="card-title">Skill 编写</h3>
          <p class="card-desc">自定义技能开发指南</p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="footer-top">
        <div class="footer-brand">
          <p class="footer-logo"><img src="/images/avatar-cropped.png" alt="宇辰" class="footer-avatar" width="28" height="28" /> 宇辰AI编程</p>
          <p class="footer-desc">AI 前沿技术与实用技巧分享，从零开始系统掌握 AI 编程工具。</p>
        </div>
        <div class="footer-links">
          <div class="footer-col">
            <p class="footer-col-title">教程</p>
            <a href="/openclaw/" class="footer-link">OpenClaw</a>
            <span class="footer-link">Claude Code</span>
            <span class="footer-link">MCP 配置</span>
          </div>
          <div class="footer-col">
            <p class="footer-col-title">关注</p>
            <span class="footer-qr-trigger">
              公众号
              <img src="/images/wechat-qrcode.png" alt="微信公众号二维码" class="footer-qr-img" width="160" height="160" />
            </span>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; 2026 宇辰AI编程</span>
        <span>learn.aiqqyc.com</span>
      </div>
    </footer>
  </div>
</StarlightPage>

<style>
  .homepage {
    max-width: 52rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  /* Profile Banner */
  .profile-banner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem 2rem;
    margin-bottom: 2.5rem;
    border-radius: 1rem;
    background-color: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-gray-5);
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.06);
  }

  .profile-avatar {
    border-radius: 50%;
    flex-shrink: 0;
  }

  .profile-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--sl-color-text);
    margin: 0 0 0.25rem;
  }

  .profile-tagline {
    font-size: 0.9rem;
    color: var(--sl-color-gray-3);
    margin: 0;
    line-height: 1.5;
  }

  /* Tutorial Sections */
  .tutorial-section {
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--sl-color-text);
    margin: 0 0 1rem;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  /* Cards */
  .tutorial-card {
    position: relative;
    border-radius: 0.75rem;
    padding: 1.5rem;
    background-color: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-gray-5);
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.06);
  }

  .tutorial-card--clickable {
    display: block;
    text-decoration: none;
    transition: all 0.3s;
  }

  .tutorial-card--clickable:hover {
    transform: translateY(-0.25rem);
    border-color: var(--sl-color-accent) !important;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
  }

  .tutorial-card--disabled {
    opacity: 0.75;
  }

  .card-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-size: 0.75rem;
    padding: 0.125rem 0.75rem;
    border-radius: 9999px;
    background-color: var(--sl-color-gray-5);
    color: var(--sl-color-gray-3);
  }

  .card-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--sl-color-text);
    margin: 0 0 0.25rem;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }

  .card-cta {
    font-weight: 600;
    color: var(--sl-color-accent);
  }

  /* Footer */
  .site-footer {
    margin-top: 1.5rem;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    gap: 3rem;
    padding: 2.5rem 0;
    border-top: 1px solid var(--sl-color-gray-5);
    align-items: flex-start;
  }

  .footer-brand {
    flex: 1;
    max-width: 20rem;
  }

  .footer-logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--sl-color-text);
    margin: 0 0 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-avatar {
    border-radius: 50%;
  }

  .footer-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  .footer-links {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col-title {
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--sl-color-text);
    margin: 0 0 0.25rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
    text-decoration: none;
  }

  a.footer-link:hover {
    color: var(--sl-color-accent);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    border-top: 1px solid var(--sl-color-gray-6);
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
  }

  .footer-qr-trigger {
    position: relative;
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
    cursor: pointer;
  }

  .footer-qr-trigger:hover {
    color: var(--sl-color-accent);
  }

  .footer-qr-img {
    display: none;
    position: absolute;
    bottom: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    border-radius: 0.5rem;
    box-shadow: 0 8px 24px rgb(0 0 0 / 0.15);
    background: white;
    padding: 0.5rem;
    z-index: 10;
  }

  .footer-qr-trigger:hover .footer-qr-img {
    display: block;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .card-grid {
      grid-template-columns: 1fr;
    }

    .footer-top {
      flex-direction: column;
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>

<style is:global>
  .content-panel:has(h1#_top) {
    display: none;
  }
</style>
